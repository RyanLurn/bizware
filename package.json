{
  "name": "bizware",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "configs/*",
      "packages/*",
      "scripts/*"
    ],
    "catalog": {
      "@t3-oss/env-core": "^0.13.10",
      "eslint": "^10.0.2",
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    },
    "catalogs": {
      "tanstack": {
        "@tanstack/react-router": "^1.163.2",
        "@tanstack/react-start": "^1.163.2"
      },
      "types": {
        "@types/bun": "^1.3.10",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3"
      },
      "ui": {
        "lucide-react": "^0.575.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.1"
      },
      "build": {
        "@rollup/plugin-babel": "^6.1.0",
        "@tailwindcss/vite": "^4.2.1",
        "@vitejs/plugin-react": "^5.1.4",
        "babel-plugin-react-compiler": "^1.0.0",
        "tsdown": "^0.20.3",
        "vite": "^7.3.1"
      }
    }
  },
  "scripts": {
    "check-types": "bun run --parallel --workspaces --if-present --no-exit-on-error check-types",
    "lint": "bun run --parallel --workspaces --if-present --no-exit-on-error lint",
    "lint:fix": "bun run --parallel --workspaces --if-present --no-exit-on-error lint:fix",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "check": "bun run check-types && bun run lint && bun run format:check",
    "sync-hooks": "bunx lefthook install",
    "main:dev": "bun --elide-lines 0 --filter @bizware/main dev",
    "db:build": "bun --elide-lines 0 --filter @bizware/db build",
    "error:build": "bun --elide-lines 0 --filter @bizware/error build",
    "ui:add": "bun --elide-lines 0 --filter @bizware/ui shadcn:add",
    "ui:build": "bun --elide-lines 0 --filter @bizware/ui build",
    "grab": "bun run --elide-lines 0 --filter @bizware/grab start"
  },
  "devDependencies": {
    "lefthook": "^2.0.16",
    "prettier": "3.8.1",
    "prettier-plugin-curly": "0.4.1",
    "prettier-plugin-tailwindcss": "0.7.2"
  },
  "packageManager": "bun@1.3.10"
}
