{
  "name": "bizware",
  "type": "module",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "configs/*",
      "packages/*"
    ],
    "catalog": {
      "eslint": "^9.39.2",
      "tsdown": "^0.20.1",
      "typescript": "^5.9.3",
      "zod": "^4.3.6"
    },
    "catalogs": {
      "tanstack": {
        "@tanstack/react-router": "^1.163.2",
        "@tanstack/react-start": "^1.163.2"
      },
      "types": {
        "@types/bun": "^1.3.10",
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3"
      },
      "ui": {
        "lucide-react": "^0.563.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.1.18"
      },
      "vite": {
        "@tailwindcss/vite": "^4.1.18",
        "@vitejs/plugin-react": "^5.1.3",
        "vite": "^7.3.1"
      }
    }
  },
  "scripts": {
    "check-types": "bun run --parallel --workspaces --if-present --no-exit-on-error check-types",
    "lint": "bun run --parallel --workspaces --if-present --no-exit-on-error lint",
    "lint:fix": "bun run --parallel --workspaces --if-present --no-exit-on-error lint:fix",
    "format": "bunx prettier . --write",
    "format:check": "bunx prettier . --check",
    "check": "bun run check-types && bun run lint && bun run format:check",
    "sync-hooks": "bunx lefthook install",
    "common:build": "bun --elide-lines 0 --filter @bizware/common build",
    "types:build": "bun --elide-lines 0 --filter @bizware/types build",
    "error:build": "bun --elide-lines 0 --filter @bizware/error build",
    "ui:add": "bun --elide-lines 0 --filter @bizware/ui shadcn:add"
  },
  "devDependencies": {
    "lefthook": "^2.0.16",
    "prettier": "3.8.1",
    "prettier-plugin-curly": "0.4.1",
    "prettier-plugin-tailwindcss": "0.7.2"
  },
  "packageManager": "bun@1.3.10"
}
