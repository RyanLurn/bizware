{
  "name": "@bizware/eslint",
  "type": "module",
  "private": true,
  "scripts": {
    "check-types": "bunx tsc --noEmit",
    "lint": "bunx eslint --cache",
    "lint:fix": "bunx eslint --cache --fix",
    "check": "bun run check-types && bun run lint"
  },
  "exports": {
    "./bun": "./src/configs/bun.js",
    "./browser": "./src/configs/browser.js",
    "./isomorphic": "./src/configs/isomorphic.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@bizware/typescript": "workspace:*",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "eslint": "catalog:",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.56.1"
  }
}
