{
  "name": "@bizware/ui",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./src/globals.css"
  },
  "scripts": {
    "build": "bunx tsdown",
    "build:watch": "bunx tsdown --watch",
    "check-types": "bunx tsc --noEmit",
    "lint": "bunx eslint --cache",
    "lint:fix": "bunx eslint --cache --fix",
    "check": "bun run check-types && bun run lint",
    "shadcn:add": "bunx --bun shadcn add"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@bizware/common": "workspace:*",
    "@bizware/error": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bizware/eslint": "workspace:*",
    "@bizware/typescript": "workspace:*",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.20.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
