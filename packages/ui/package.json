{
  "name": "@bizware/ui",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./utils": {
      "import": "./dist/utils.mjs",
      "types": "./dist/utils.d.mts"
    },
    "./theme": {
      "import": "./dist/theme.mjs",
      "types": "./dist/theme.d.mts"
    },
    "./form": {
      "import": "./dist/form.mjs",
      "types": "./dist/form.d.mts"
    },
    "./style.css": "./src/globals.css"
  },
  "scripts": {
    "build": "bunx tsdown",
    "build:watch": "bunx tsdown --watch",
    "check-types": "bunx tsc --noEmit",
    "lint": "bunx eslint --cache",
    "lint:fix": "bunx eslint --cache --fix",
    "check": "bun run check-types && bun run lint",
    "shadcn:add": "bunx --bun shadcn add"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@bizware/common": "workspace:*",
    "@bizware/error": "workspace:*",
    "@tanstack/react-form": "^1.28.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "lucide-react": "catalog:ui",
    "react": "catalog:ui",
    "react-dom": "catalog:ui",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@bizware/eslint": "workspace:*",
    "@bizware/typescript": "workspace:*",
    "@rollup/plugin-babel": "catalog:build",
    "@types/bun": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "babel-plugin-react-compiler": "catalog:build",
    "eslint": "catalog:",
    "shadcn": "^3.8.5",
    "tailwindcss": "catalog:ui",
    "tsdown": "catalog:build",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:"
  }
}
