{
  "name": "@bizware/common",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bunx tsdown",
    "build:watch": "bunx tsdown --watch",
    "try": "bun run test/try.ts",
    "check-types": "bunx tsc --noEmit",
    "lint": "bunx eslint --cache",
    "lint:fix": "bunx eslint --cache --fix",
    "check": "bun run check-types && bun run lint"
  },
  "exports": {
    "./ports": {
      "import": "./src/constants/ports.js",
      "types": "./src/constants/ports.d.ts"
    },
    "./types/brand": {
      "types": "./src/types/brand.ts"
    },
    "./types/result": {
      "types": "./src/types/result.ts"
    }
  },
  "devDependencies": {
    "@bizware/eslint": "workspace:*",
    "@bizware/typescript": "workspace:*",
    "@types/bun": "catalog:types",
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
